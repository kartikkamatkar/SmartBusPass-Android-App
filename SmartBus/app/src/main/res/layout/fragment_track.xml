<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_off_white">

    <!-- OpenStreetMap View (Free Solution) -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_view_track"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Floating Search Bar (30dp lower than top) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/search_card_track"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="50dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/text_secondary" />

            <AutoCompleteTextView
                android:id="@+id/et_track_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Search bus stop or route"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Map Controls (Floating) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:orientation="vertical">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_layers_track"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@android:drawable/ic_menu_gallery"
            app:fabSize="mini"
            app:tint="@color/text_secondary" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_my_location_track"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_mylocation"
            app:fabSize="mini"
            app:tint="@color/primary_red" />
    </LinearLayout>

    <!-- Bottom Sheet for Bus Info -->
    <include layout="@layout/layout_track_bottom_sheet" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

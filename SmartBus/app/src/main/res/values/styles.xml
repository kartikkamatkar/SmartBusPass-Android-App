<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SmartBus.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/primary_red</item>
        <item name="titleTextColor">@color/accent_white</item>
    </style>

    <style name="SmartBus.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="android:textColor">@color/accent_white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:stateListAnimator">@animator/button_press_scale</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="SmartBus.Input" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:padding">12dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="SmartBus.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/accent_white</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">3dp</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="SmartBus_Dialog_Center" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
    </style>
</resources>

